---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	canonicalURL?: string;
}

const SITE_URL = "https://daggrykaffe.dk";
const DEFAULT_DESCRIPTION = "daggry – bageri & kaffebar i Lyngby. Surdejsbrød, krystalost og lysristet specialkaffe. Åbent alle dage 06.30–17.00.";

const {
	title,
	description = DEFAULT_DESCRIPTION,
	ogImage = "/og.png",
	canonicalURL = new URL(Astro.url.pathname, SITE_URL).href,
} = Astro.props;

const ogImageURL = new URL(ogImage, SITE_URL).href;
---

<!doctype html>
<html lang="da">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="daggry – bageri & kaffebar i Lyngby" />
		<meta property="og:locale" content="da_DK" />
		<meta property="og:site_name" content="daggry" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<meta name="twitter:image:alt" content="daggry – bageri & kaffebar i Lyngby" />

		<!-- Additional SEO -->
		<meta name="theme-color" content="#F4F1EB" />
		<meta name="robots" content="index, follow" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cutive+Mono&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen font-sans bg-bg text-text leading-relaxed overflow-x-hidden">
		<slot />

		<!-- Local Business structured data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Bakery",
			"name": "daggry",
			"description": DEFAULT_DESCRIPTION,
			"url": SITE_URL,
			"telephone": "+4526339906",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Lyngby Hovedgade 66",
				"addressLocality": "Kongens Lyngby",
				"postalCode": "2800",
				"addressCountry": "DK"
			},
			"openingHoursSpecification": {
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
				"opens": "06:30",
				"closes": "17:00"
			},
			"servesCuisine": ["Bakery", "Coffee"],
			"priceRange": "$$",
			"image": ogImageURL,
			"sameAs": ["https://instagram.com/daggrykaffe"]
		})} />
	</body>
</html>
