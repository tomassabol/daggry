---
interface Props {
  name: string;
  price?: string;
  description?: string;
}

const { name, price, description } = Astro.props;
const descLines = description ? description.split("\\n") : [];
---

<article class="flex flex-col gap-1 relative">
  <div class="flex justify-between items-baseline gap-4">
    <h3
      class="font-sans text-[1.1rem] font-medium m-0 leading-[1.4] max-sm:text-[1rem]"
    >
      {name}
    </h3>
    {
      price && (
        <span class="font-sans text-[1.1rem] font-normal whitespace-nowrap max-sm:text-[1rem]">
          {price}
        </span>
      )
    }
  </div>

  {
    description && (
      <div class="font-sans text-[0.9rem] text-text-light leading-[1.4] max-w-[85%] max-sm:text-[0.85rem] max-sm:max-w-[90%]">
        {descLines.map((line) => (
          <p class="m-0">{line}</p>
        ))}
      </div>
    )
  }
</article>
